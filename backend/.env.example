# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Server
PORT=3001
NODE_ENV=development

# CORS – frontend origin
CORS_ORIGIN=http://localhost:5173

# Demo admin key – required to call POST /orders/:num/advance
# Leave unset in local dev for open access; set to any secret string in production
DEMO_ADMIN_KEY=

# Support escalation contact – injected into the AI system prompt for fail-safe replies
# When unset the prompt falls back to generic "contact our support team" text
SUPPORT_EMAIL=support@marqet.com
SUPPORT_PHONE=+91-XXXXXXXXXX
